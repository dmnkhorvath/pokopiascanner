# Ad Provider: 'adsense', 'adsterra', or leave empty for auto-detect
# Auto-detect prefers Adsterra if keys are set, else falls back to AdSense
VITE_AD_PROVIDER=

# Adsterra Banner Keys
VITE_ADSTERRA_DESKTOP_KEY=your-adsterra-728x90-key
VITE_ADSTERRA_MOBILE_KEY=your-adsterra-320x50-key

# Google AdSense
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXX
VITE_AD_SLOT_LANDING_TOP=1234567890
VITE_AD_SLOT_LANDING_BOTTOM=1234567891
VITE_AD_SLOT_SCANNER_TOP=1234567892
VITE_AD_SLOT_SCANNER_BOTTOM=1234567893

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Base path (set to / if serving from root)
VITE_BASE_PATH=/

# Cloudflare Cache Purge (used by docker-compose cache-purge service)
# Get Zone ID from: Cloudflare Dashboard → your domain → Overview → right sidebar → API section
# Create API Token at: Cloudflare Dashboard → My Profile → API Tokens → Create Custom Token
#   Permission: Zone → Cache Purge → Purge
#   Zone Resources: Include → Specific zone → your domain
CF_ZONE_ID=your-cloudflare-zone-id
CF_API_TOKEN=your-cloudflare-api-token
CF_PURGE_DOMAIN=https://dominikh.com
